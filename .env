# --- Auth secrets ---
JWT_ACCESS_SECRET=cf1e7ae51b8dfcb2f1f88e3499bac8fa64ee3490ea8ca77bcadf61afac4a8871
JWT_REFRESH_SECRET=2a94e79090fc95cbe009b3cdbb18a9cf1f23a5c18f6705eb44eaecb2dffff31e

