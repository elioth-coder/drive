# Campus Management — production deployment environment.
# Consumed by docker-compose.yml in this folder. Never commit this file (it holds real secrets).

# --- Compose / Docker ---
# Container/volume name prefix. Kept distinct from a dev stack running on the same box.
COMPOSE_PROJECT_NAME=campus-prod

# Registry + namespace. Images are pulled as <prefix>/campus-{api,web}:${APP_VERSION}.
IMAGE_PREFIX=ghcr.io/elioth-coder/campus-management

# The version to run = the image tag. Bump this and re-run `docker compose pull && docker compose up -d`
# to update (see docs/DEPLOYMENT.md "Updating a box").
APP_VERSION=1.0.7

# Host port the web UI is served on.
HTTP_PORT=8080

# --- Database (first-run bootstrap only; changing later does not rename an existing DB) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=3d3f940aa4f522bd6b9e740785f5ceab92e2aa44
POSTGRES_DB=campus

# --- Auth secrets (pre-generated with `openssl rand -hex 32` — unique to this deployment) ---
JWT_ACCESS_SECRET=69485719b3a34dcfccf9ab41735ddbf7384dc7f2849701e592b7c72d659c3a1c
JWT_REFRESH_SECRET=583decfeaadf45c613e769b2bfcb327d311578f38f3aec12cf30379dab733720

# --- CORS ---
# MUST match the URL this app is actually accessed at (scheme + host + port), or the browser
# will be blocked by CORS. Edit before first boot if not running on localhost, e.g.
# http://203.0.113.10 or https://campus.example.edu.
WEB_URL=http://localhost
